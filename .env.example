# Projects DB (required)
PROJECTS_POSTGRES_DSN=host=localhost port=5433 user=robbo_projects password=robbo_projects_change_me dbname=robbo_projects sslmode=disable

# Legacy LK Postgres — disabled in two-DB mode
LEGACY_POSTGRES_ENABLED=false

# Open edX MySQL read-only (workers/scripts; local dump on :3307)
LMS_MYSQL_DSN=lk_readonly:lk_readonly_change_me@tcp(localhost:3307)/openedx

# Auth: oidc_bff + fallback = OAuth first, else email/password vs LMS MySQL
AUTH_MODE=oidc_bff
AUTH_LMS_PASSWORD_FALLBACK=true
LK_SSO_WITH_LMS_ENABLED=true

# OIDC (only when AUTH_MODE=oidc_bff)
# Docker app service: authorize/issuer use localhost (browser); token/jwks use host.docker.internal — see docker-compose.yml
OIDC_ISSUER=http://localhost:8081/default
OIDC_AUTHORIZATION_ENDPOINT=http://localhost:8081/default/authorize
OIDC_TOKEN_ENDPOINT=http://localhost:8081/default/token
OIDC_JWKS_URI=http://localhost:8081/default/jwks
OIDC_CLIENT_ID=lk-web
OIDC_REDIRECT_URI=http://localhost:8080/auth/oidc/callback
OIDC_LOGOUT_ENDPOINT=
OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:3030/login
OIDC_FRONTEND_BASE_URL=http://localhost:3030

AUTH_ACCESS_SIGNING_KEY=change-me
AUTH_REFRESH_SIGNING_KEY=change-me
AUTH_HASH_SALT=change-me

# CORS: для локальной сети (http://192.168.x.x:3030) включить true; prod — false + CORS_ALLOWED_ORIGINS
CORS_ALLOW_PRIVATE_NETWORK=true
# CORS_ALLOWED_ORIGINS=https://lk.example.com,https://staging.example.com

LMS_NOTIFICATIONS_ENABLED=false
LMS_NOTIFICATIONS_INGEST_TOKEN=

PORTAL_OUTBOX_ENABLED=true

API_TOKEN=
API_CLIENT_ID=
API_CLIENT_SECRET=

# YooKassa for RS3 license checkout (Phase 2). Prefer env over committing into config.yml.
PAYMENTS_YOOKASSA_SHOP_ID=
PAYMENTS_YOOKASSA_SECRET_KEY=
